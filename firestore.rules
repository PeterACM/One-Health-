rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global safety net - deny everything by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper to check valid document IDs
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Helper to extract incoming resource data
    function incoming() {
      return request.resource.data;
    }

    // Helper to validate TextEdit schema
    function isValidTextEdit(data) {
      return data.keys().hasAll(['text', 'updatedAt']) 
        && data.keys().size() == 2
        && data.text is string 
        && data.text.size() <= 10000
        && data.updatedAt is string
        && data.updatedAt.size() <= 128;
    }

    // Helper to validate HistoryEntry schema
    function isValidHistoryEntry(data) {
      return data.keys().hasAll(['id', 'textId', 'timestamp', 'oldValue', 'newValue', 'createdAt'])
        && data.keys().size() == 6
        && data.id is string
        && data.id.size() <= 128
        && data.textId is string
        && data.textId.size() <= 128
        && data.timestamp is string
        && data.timestamp.size() <= 128
        && data.oldValue is string
        && data.oldValue.size() <= 10000
        && data.newValue is string
        && data.newValue.size() <= 10000
        && data.createdAt is number;
    }

    // Match rules for edits collection
    match /edits/{textId} {
      allow read: if true;
      allow create, update: if isValidId(textId) && isValidTextEdit(incoming());
      allow delete: if isValidId(textId);
    }

    // Match rules for history collection
    match /history/{entryId} {
      allow read: if true;
      allow create, update: if isValidId(entryId) && isValidHistoryEntry(incoming());
      allow delete: if isValidId(entryId);
    }
  }
}
